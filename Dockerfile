# 1. Базовый образ
FROM node:20

# 2. Рабочая директория внутри контейнера
WORKDIR /app

# 3. Копируем package.json и package-lock.json отдельно, чтобы использовать кеш
COPY package*.json ./

# 4. Устанавливаем зависимости
RUN npm install

# 5. Копируем весь проект в контейнер
COPY . .

# 6. Открываем порт для Nuxt (по умолчанию 3000)
EXPOSE 3000

# 7. Запуск приложения в режиме разработки
CMD ["npm", "run", "dev"]
